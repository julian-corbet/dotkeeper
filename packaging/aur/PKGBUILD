# Maintainer: Julian Corbet <julian.corbet@gmail.com>
pkgname=dotkeeper-bin
pkgver=0.1.0
pkgrel=1
pkgdesc="P2P repo sync with git history — embedded Syncthing + git auto-backup"
arch=('x86_64' 'aarch64')
url="https://dotkeeper.corbet.ch"
license=('AGPL-3.0-only')
depends=('git')
provides=('dotkeeper')
conflicts=('dotkeeper')
source_x86_64=("https://github.com/julian-corbet/dotkeeper/releases/download/v${pkgver}/dotkeeper_${pkgver}_linux_amd64.tar.gz")
source_aarch64=("https://github.com/julian-corbet/dotkeeper/releases/download/v${pkgver}/dotkeeper_${pkgver}_linux_arm64.tar.gz")
sha256sums_x86_64=('PLACEHOLDER')
sha256sums_aarch64=('PLACEHOLDER')

package() {
    cd "dotkeeper_${pkgver}_linux_${CARCH/x86_64/amd64}"
    cd "${srcdir}/dotkeeper_${pkgver}_linux_$([ "$CARCH" = "x86_64" ] && echo "amd64" || echo "arm64")"
    install -Dm755 dotkeeper "${pkgdir}/usr/bin/dotkeeper"
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
    install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
    install -Dm644 dotkeeper.toml.example "${pkgdir}/usr/share/doc/${pkgname}/dotkeeper.toml.example"
}
