# dotkeeper — shared config
# This file is created by `dotkeeper init` at ~/.config/dotkeeper/config.toml
# and synced between machines via Syncthing.
# You can also copy this template and edit manually.

[sync]
# How often git backs up your repos. Syncthing handles real-time sync.
# Options: "hourly", "2h", "6h", "12h", "daily" (default), "weekly", "monthly"
# Or any systemd OnCalendar expression for custom schedules.
git_interval = "daily"

# Stagger window: each machine slot offsets by this many minutes
slot_offset_minutes = 5

[syncthing]
# Patterns excluded from Syncthing sync (written to .stignore in each folder).
# These are defaults — edit to match your workflow.
# NOTE: lockfiles (package-lock.json, yarn.lock, etc.) are NOT excluded
# because they are source files that should sync between machines.
ignore = [
    # Version control — git state is managed separately by dotkeeper
    ".git",

    # Syncthing internals — conflict files must not propagate
    "*.sync-conflict-*",
    ".stfolder",
    ".stignore",

    # OS metadata
    "(?d).DS_Store",
    "(?d)Thumbs.db",
    "(?d)desktop.ini",

    # Build artifacts — reproducible from source
    "*-bin",
    "*.exe",
    "*.dll",
    "*.so",
    "*.dylib",
    "*.o",
    "*.a",
    "__debug_bin*",
    "/target",      # Rust (root only to avoid false positives)
    "/dist",
    "/build",
    "/out",

    # Dependency directories — reproducible via package manager
    "node_modules",
    ".venv",
    "venv",
    "__pycache__",
    "*.pyc",
    "*.pyo",
    ".eggs",
    "*.egg-info",

    # Databases and journals — cause constant conflicts when open
    "*.sqlite3",
    "*.sqlite3-journal",
    "*.sqlite3-wal",
    "*.sqlite3-shm",
    "*.sqlite",
    "*.sqlite-journal",
    "*.sqlite-wal",
    "*.sqlite-shm",

    # Process runtime state — machine-local
    "*.pid",
    "*.sock",

    # Log files
    "*.log",
    "*.log.*",

    # Editor swap/backup — syncing these makes the other editor think it crashed
    "*.swp",
    "*.swo",
    ".*.swp",
    ".*.swo",
    "*~",
    "#*#",

    # JetBrains .idea/ — sync project config, exclude volatile state
    ".idea/workspace.xml",
    ".idea/tasks.xml",
    ".idea/usage.statistics.xml",
    ".idea/shelf",
    ".idea/caches",
    ".idea/*.iws",

    # VS Code — sync settings/launch/tasks, exclude logs
    ".vscode/*.log",

    # Caches and framework temp dirs
    ".cache",
    ".parcel-cache",
    ".next",
    ".nuxt",
    ".turbo",
    ".angular",
    ".sass-cache",
    ".pytest_cache",
    ".mypy_cache",
    ".ruff_cache",
    ".tox",
    ".gradle",
    "coverage",
    "htmlcov",

    # Temporary files
    "*.tmp",
    "*.temp",
    "*.bak",
    "*.orig",
]

# Machines participating in sync.
# Each machine registers itself via `dotkeeper init`, then you add it here.
[machines]

# [machines.desktop]
# hostname = "my-desktop"
# slot = 0
# syncthing_id = "XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX"

# [machines.laptop]
# hostname = "my-laptop"
# slot = 1
# syncthing_id = "YYYYYYY-YYYYYYY-YYYYYYY-YYYYYYY-YYYYYYY-YYYYYYY-YYYYYYY-YYYYYYY"

# Repos to keep in sync.
# path supports ~ expansion.
# git = true means dotkeeper will auto-commit/push on the git timer.
[[repos]]
name = "dotkeeper"
path = "~/Documents/GitHub/dotkeeper"
git = true

# [[repos]]
# name = "my-project"
# path = "~/Documents/GitHub/my-project"
# git = true
