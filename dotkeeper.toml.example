# dotkeeper — per-repo configuration example
#
# In v0.5, every repo dotkeeper manages has a `dotkeeper.toml` at its root,
# committed to git. The presence of this file is the opt-in signal: dotkeeper
# only manages repos that carry one. See ADR 0001 for the rationale.
#
# This file is one of three v0.5 config locations:
#
#   <repo>/dotkeeper.toml                        — this file (per-repo, in git)
#   $XDG_CONFIG_HOME/dotkeeper/machine.toml      — per-machine (run `dotkeeper init`)
#   $XDG_STATE_HOME/dotkeeper/state.toml         — per-machine, tool-owned
#
# `dotkeeper init` scaffolds machine.toml and state.toml. You typically don't
# author dotkeeper.toml by hand either — once a repo lands in a configured
# scan_root and you run `dotkeeper reconcile`, the daemon writes one for you.
# This example documents the schema for the curious and for anyone authoring
# by hand for a repo outside the scan_roots (registered via `dotkeeper track`).

schema_version = 2

[repo]
# Human-readable name for this repo. Doesn't have to match the directory name.
name = "my-project"

# RFC3339 timestamp marking when dotkeeper first started managing this repo.
added = "2026-04-26T00:00:00Z"

# Name (from machine.toml) of the machine that first added this repo.
added_by = "desktop"

[sync]
# Syncthing folder ID. Conventionally `dk-<short-name>`. Generated automatically
# by the reconciler if empty on first reconcile.
syncthing_folder_id = "dk-my-project"

# Per-repo Syncthing ignore patterns, MERGED with machine-level defaults.
# Patterns follow Syncthing's .stignore syntax.
ignore = [
    # `(?d)` makes the pattern delete-only — Syncthing won't propagate the
    # file but will allow other peers to delete their copies.
    "(?d).DS_Store",

    # Local-only large artifacts you don't want crossing the mesh.
    "node_modules/.cache",
    ".next/",
]

# Peer device names that should receive this repo. Names refer to entries in
# state.toml's [[peers]] table. Empty means inherit `default_share_with` from
# machine.toml.
share_with = ["laptop", "vps"]

[commit]
# Auto-commit policy for dirty trees in this repo.
#   "manual"  — never auto-commit (default)
#   "on-idle" — auto-commit after `idle_seconds` of no further changes
#   "timer"   — auto-commit on the same schedule as the git backup
policy = "manual"

# Inactivity threshold for the "on-idle" policy. Ignored otherwise.
idle_seconds = 300

[git_backup]
# How often this repo gets pushed to its git remote. Inherits from
# machine.toml's `default_git_interval` if empty.
#
# Accepted values: "hourly", "2h", "6h", "12h", "daily", "weekly", "monthly",
# or any systemd OnCalendar expression.
interval = "hourly"

# Slot numbers (from machine.toml `slot`) that should NOT run a backup for this
# repo. Use this to avoid redundant pushes when several machines all see the
# same repo. Empty list means every slot backs up.
skip_slots = []
