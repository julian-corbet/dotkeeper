# Build output
/dotkeeper
/dotkeeper-bin
!cmd/dotkeeper/
*.exe
__debug_bin*

# Syncthing artifacts (generated by dotkeeper pair/add)
.stignore
.dkfolder/
.stfolder/
*.sync-conflict-*

# Editor
*.swp
*.swo
*~
dist/
.wrangler/

# Coverage output (generated by `make cover`)
coverage.out
coverage.html

# Local tooling context stays outside this repository.
# Keep these out of the public repo. No trailing slash so the patterns
# also match symlinks (which git treats as files, not directories).
.local-tools
.local-notes
