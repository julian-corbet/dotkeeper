# Test image for multipeer e2e scenarios.
#
# Builds dotkeeper from the working tree (not a pinned release) so each PR
# tests its own code. Adds git, coreutils, and a small set of network/diag
# utilities used by adversarial scenarios (iptables for partition tests,
# libfaketime for clock-skew tests).
#
# Build context is the repo root: `docker build -f tests/multipeer/Dockerfile.test .`

# --- Build stage ---
FROM golang:1.26-alpine AS build
WORKDIR /src
RUN apk add --no-cache git
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -tags noassets -o /out/dotkeeper ./cmd/dotkeeper

# --- Runtime stage ---
FROM alpine:3.20
RUN apk add --no-cache \
    git \
    bash \
    coreutils \
    findutils \
    curl \
    jq \
    iptables \
    procps \
    tini \
    libfaketime \
    tzdata
COPY --from=build /out/dotkeeper /usr/local/bin/dotkeeper

# Test harness drives lifecycle via `docker exec`. Container just idles so the
# harness can shell in and run dotkeeper subcommands deterministically. This
# avoids racing the daemon startup against test setup.
ENTRYPOINT ["/sbin/tini", "--"]
CMD ["sleep", "infinity"]
